{
  "metadata": {
    "title": "Cosmic Horror Index Dataset",
    "version": "1.0.0",
    "description": "Structured scoring of cosmological systems against Lovecraftian cosmic horror axes",
    "methodology": {
      "axes": [
        {
          "id": "omniscience",
          "label": "Omniscience",
          "description": "Does the entity/system know everything?",
          "weight": 1
        },
        {
          "id": "omnipotence",
          "label": "Omnipotence",
          "description": "Can it do anything?",
          "weight": 1
        },
        {
          "id": "self_sufficiency",
          "label": "Self-sufficiency",
          "description": "Does it need anything from creation?",
          "weight": 1
        },
        {
          "id": "indifference",
          "label": "Indifference",
          "description": "Does it care about humans?",
          "weight": 2
        },
        {
          "id": "incomprehensibility",
          "label": "Incomprehensibility",
          "description": "Can humans understand it?",
          "weight": 2
        },
        {
          "id": "human_insignificance",
          "label": "Human insignificance",
          "description": "Do humans matter in this system?",
          "weight": 2
        },
        {
          "id": "cyclical_destruction",
          "label": "Cyclical destruction",
          "description": "Does the cosmos destroy and rebuild?",
          "weight": 1
        },
        {
          "id": "awe_madness",
          "label": "Awe / madness induction",
          "description": "Does encountering the truth break humans?",
          "weight": 1
        },
        {
          "id": "creation_without_consent",
          "label": "Creation without consent",
          "description": "Were humans made without being asked?",
          "weight": 1
        },
        {
          "id": "moral_neutrality",
          "label": "Moral neutrality",
          "description": "Is it beyond good and evil?",
          "weight": 1
        }
      ],
      "chi_formula": "weighted_mean(axes, weights) where indifference, incomprehensibility, human_insignificance are 2x weighted",
      "scoring_basis": "Primary theological/philosophical claims from canonical texts, not popular understanding. 0 = anti-Lovecraftian, 100 = peak cosmic horror."
    }
  },
